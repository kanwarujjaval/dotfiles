[user]
	name = {{ .full_name }}
	email = {{ .email }}
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIBQOqVUXiWB2r3uZ14L5LiEskwUKbJG/ESlyjaEiJe8E

[gpg]
	format = ssh

{{- if eq .chezmoi.os "darwin" }}

[gpg "ssh"]
	program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"
{{- else }}

[gpg "ssh"]
	allowedSignersFile = ~/.ssh/allowed_signers
{{- end }}

[commit]
	gpgsign = true

[diff]
	colorMoved = default

[core]
	autocrlf = input
	editor = vim

[merge]
	conflictstyle = diff3
	tool = vimdiff

[pull]
	ff = only

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[include]
	path = ~/.gitconfig.local
