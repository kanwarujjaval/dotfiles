#!/bin/bash
# packages.yaml hash: {{ include ".chezmoidata/packages.yaml" | sha256sum }}

{{ if eq .chezmoi.os "darwin" -}}
brew bundle --file="{{ .chezmoi.homeDir }}/Brewfile"
{{ else if eq .chezmoi.os "linux" -}}
sudo apt update
sudo apt install -y{{ range .packages.apt }}{{ range .packages }} {{ . }}{{ end }}{{ end }}

# starship (not in default apt repos, install to ~/.local/bin)
if ! command -v starship &> /dev/null; then
  mkdir -p "{{ .chezmoi.homeDir }}/.local/bin"
  curl -sS https://starship.rs/install.sh | sh -s -- -y --bin-dir "{{ .chezmoi.homeDir }}/.local/bin"
fi

# zoxide (installs to ~/.local/bin by default)
if ! command -v zoxide &> /dev/null; then
  curl -sSfL https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/install.sh | sh
fi

# chezmoi — ensure it's on PATH (installer puts it in ~/bin)
if [ -f "{{ .chezmoi.homeDir }}/bin/chezmoi" ] && [ ! -f "{{ .chezmoi.homeDir }}/.local/bin/chezmoi" ]; then
  ln -sf "{{ .chezmoi.homeDir }}/bin/chezmoi" "{{ .chezmoi.homeDir }}/.local/bin/chezmoi"
fi

# Ubuntu binary name aliases (bat→batcat, fd→fdfind)
if command -v batcat &> /dev/null && ! command -v bat &> /dev/null; then
  ln -sf "$(which batcat)" "{{ .chezmoi.homeDir }}/.local/bin/bat"
fi
if command -v fdfind &> /dev/null && ! command -v fd &> /dev/null; then
  ln -sf "$(which fdfind)" "{{ .chezmoi.homeDir }}/.local/bin/fd"
fi

# eza (not in default apt repos)
if ! command -v eza &> /dev/null; then
  sudo mkdir -p /etc/apt/keyrings
  wget -qO- https://raw.githubusercontent.com/eza-community/eza/main/deb.asc | sudo gpg --dearmor -o /etc/apt/keyrings/gierens.gpg
  echo "deb [signed-by=/etc/apt/keyrings/gierens.gpg] http://deb.gierens.de stable main" | sudo tee /etc/apt/sources.list.d/gierens.list
  sudo apt update
  sudo apt install -y eza
fi

# Docker Engine (official apt repository)
if ! command -v docker &> /dev/null; then
  sudo install -m 0755 -d /etc/apt/keyrings
  sudo curl -fsSL https://download.docker.com/linux/ubuntu/gpg -o /etc/apt/keyrings/docker.asc
  sudo chmod a+r /etc/apt/keyrings/docker.asc

  sudo tee /etc/apt/sources.list.d/docker.sources <<DOCKEREOF
Types: deb
URIs: https://download.docker.com/linux/ubuntu
Suites: $(. /etc/os-release && echo "${UBUNTU_CODENAME:-$VERSION_CODENAME}")
Components: stable
Signed-By: /etc/apt/keyrings/docker.asc
DOCKEREOF

  sudo apt update
  sudo apt install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
  sudo usermod -aG docker "$USER"
fi

# Tailscale (official install script handles repo setup)
if ! command -v tailscale &> /dev/null; then
  curl -fsSL https://tailscale.com/install.sh | sh
fi

# sesh (smart tmux session manager — not in default apt repos)
if ! command -v sesh &> /dev/null; then
  SESH_URL="https://github.com/joshmedeski/sesh/releases/latest/download/sesh_Linux_x86_64.tar.gz"
  curl -fsSL "$SESH_URL" | tar xz -C /tmp sesh
  mv /tmp/sesh "{{ .chezmoi.homeDir }}/.local/bin/sesh"
  chmod +x "{{ .chezmoi.homeDir }}/.local/bin/sesh"
fi

# fnm (Fast Node Manager — not in default apt repos)
if ! command -v fnm &> /dev/null; then
  curl -fsSL https://fnm.vercel.app/install | bash -s -- --install-dir "{{ .chezmoi.homeDir }}/.local/bin" --skip-shell
fi
{{ end -}}

# Install default Node.js LTS via fnm if no node available
if command -v fnm &> /dev/null; then
  eval "$(fnm env)"
  if ! command -v node &> /dev/null; then
    fnm install --lts
  fi
fi

# npm global packages (all platforms, requires node)
if command -v npm &> /dev/null; then
{{- range .packages.npm }}
  if ! command -v {{ . }} &> /dev/null; then
    npm install -g {{ . }}
  fi
{{- end }}
fi
