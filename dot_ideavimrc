" ========== Core Vim Settings ==========
set number
set relativenumber
set ignorecase
set smartcase
set hlsearch
set incsearch
set scrolloff=8
set sidescrolloff=8
set clipboard+=unnamed
set clipboard+=ideaput
set showmode
set showcmd
set visualbell
set noerrorbells

" ========== Leader Key ==========
let mapleader = " "

" ========== Insert Mode Escape ==========
inoremap jk <Esc>
inoremap kj <Esc>

" ========== Vim Plugin Activation (IdeaVim supported) ==========
set surround
set multiple-cursors
set commentary
set argtextobj
set exchange
set textobj-entire
set ReplaceWithRegister
set highlightedyank
set vim-paragraph-motion
set textobj-indent
set matchit
set easymotion
set quickscope
set sneak
set which-key
set NERDTree

" ========== IdeaVim-Specific Options ==========
set ideajoin
set ideastatusicon=gray
set idearefactormode=keep

" ========== Which-Key Settings ==========
